# ─── Supabase ────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER-SIDE ONLY. Never expose to the browser.
# Used by API routes and seed scripts to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Google Maps ─────────────────────────────────────────────
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Enable: Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ─── Resend (email) ──────────────────────────────────────────
# Create at: resend.com → API Keys
RESEND_API_KEY=re_your-resend-key-here

# Email address to receive admin digests and "This changed" alerts
FOUNDER_EMAIL=you@example.com

# ─── PostHog (analytics) ─────────────────────────────────────
# Found at: app.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key-here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Cron security ───────────────────────────────────────────
# Any long random string — used to authorize calls to /api/digest
# Generate with: openssl rand -base64 32
CRON_SECRET=your-random-secret-here
